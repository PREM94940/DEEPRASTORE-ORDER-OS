# Deeprastore Order OS - Environment Variables Example
# Do not place production credentials in this file.

# Application Environment
# Valid values: 'development', 'staging', 'production'
APP_ENV=development

# Database Connection
# IMPORTANT: For local development, this MUST point to your Development Supabase instance.
# Example format: postgresql://postgres.[project-id]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[dev-project-id]:[dev-password]@aws-0-[dev-region].pooler.supabase.com:6543/postgres

# NextAuth Configuration (if applicable)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=local-development-secret

# Supabase Auth / Storage (Public)
NEXT_PUBLIC_SUPABASE_URL=https://[dev-project-id].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
